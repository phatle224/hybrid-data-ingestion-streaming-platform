{
  "name": "postgresql-staging-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "postgres",
    "database.dbname": "postgres",
    "topic.prefix": "staging",
    "schema.include.list": "staging",
    "table.include.list": "staging.stgInsuranceContract,staging.stgInsuranceContractObject,staging.stgInsuranceContractObjectVehicle,staging.stgInsuranceContractObjectTravel,staging.stgInsuranceContractObjectMoto,staging.stgInsuranceContractObjectSocialInsurance,staging.stgInsuranceContractObjectMedicalInsurance,staging.stgInsuranceContractObjectHouse,staging.stgInsuranceContractObjectOffline,staging.stgInsuranceClaim",
    "plugin.name": "pgoutput",
    "tombstones.on.delete": "false",
    "snapshot.mode": "always",
    "decimal.handling.mode": "double",
    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",
    "heartbeat.interval.ms": "10000"
  }
}
