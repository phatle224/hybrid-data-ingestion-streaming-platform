{
  "name": "postgresql-source-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "postgres",
    "database.dbname": "postgres",
    "topic.prefix": "source",
    "schema.include.list": "public",
    "table.include.list": "public.insuranceContract,public.insuranceContractObject,public.insuranceContractObjectVehicle,public.insuranceContractObjectTravel,public.insuranceContractObjectMoto,public.insuranceContractObjectSocialInsurance,public.insuranceContractObjectMedicalInsurance,public.insuranceContractObjectHouse,public.insuranceClaim",
    "plugin.name": "pgoutput",
    "tombstones.on.delete": "false",
    "snapshot.mode": "always",
    "decimal.handling.mode": "double",
    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",
    "heartbeat.interval.ms": "10000"
  }
}
