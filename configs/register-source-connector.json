{
  "name": "postgresql-source-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "database.hostname": "host.docker.internal",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "Lhp542004@",
    "database.dbname": "insuranceSale",
    "topic.prefix": "source",
    "schema.include.list": "source",
    "table.include.list": "source.insuranceContract,source.insuranceContractObject,source.insuranceContractObjectVehicle,source.insuranceContractObjectTravel,source.insuranceContractObjectMoto,source.insuranceContractObjectSocialInsurance,source.insuranceContractObjectMedicalInsurance,source.insuranceContractObjectHouse,source.insuranceClaim",
    "plugin.name": "pgoutput",
    "slot.name": "debezium_source",
    "publication.name": "dbz_publication_source",
    "tombstones.on.delete": "false",
    "snapshot.mode": "always",
    "decimal.handling.mode": "double",
    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",
    "publication.autocreate.mode": "filtered",
    "heartbeat.interval.ms": "10000"
  }
}
