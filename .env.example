# CDC Server - Environment Configuration Template
# This file shows all required environment variables for the CDC pipeline
# 
# SETUP INSTRUCTIONS:
# 1. Copy to .env: cp .env.example .env
# 2. Update with your actual values
# 3. DO NOT commit .env to Git

# ===================================
# Kafka Configuration
# ===================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
# Internal Docker network address
# Use kafka:9093 for containers, localhost:9092 for host

KAFKA_GROUP_ID=server-consumer-v14
# Consumer group ID - change if you need separate consumer groups

# ===================================
# PostgreSQL Database (Local Windows Host / Docker)
# ===================================
# If running containers, use host.docker.internal to connect to PostgreSQL running on Windows Host.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=postgres
# Staging and source schemas will reside within this database.

# ===================================
# Topic Prefix (MUST match Debezium connector)
# ===================================
TOPIC_PREFIX=source.public
# Must match "topic.prefix" in Debezium connector config.
# Topics created: {prefix}.insuranceContract, {prefix}.insuranceContractObject, etc.

# ===================================
# Python Consumer Configuration
# ===================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG for troubleshooting (very verbose)

CONSUMER_TIMEOUT_MS=1000
# Time to wait for messages before timeout

MAX_POLL_INTERVAL_MS=300000
# Maximum interval between polls (5 minutes)

MAX_POLL_RECORDS=500
# Maximum records to fetch per poll

AUTO_OFFSET_RESET=earliest
# Options: earliest, latest, none
# earliest = read from beginning if no offset stored
# latest = only read new messages

# ===================================
# Redis Configuration
# ===================================
REDIS_HOST=cdc_redis
REDIS_PORT=6379
REDIS_PASSWORD=admin
REDIS_DB=0
